# 💎 Finora Bot — Переменные окружения для Railway

# ═══════════════════════════════════════════════════════════════════
# ОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ
# ═══════════════════════════════════════════════════════════════════

# Telegram Bot Token (от @BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# OpenRouter API Key (для AI)
OPENROUTER_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL (Railway создает автоматически)
DATABASE_URL=postgresql://postgres:password@host:5432/railway
DATABASE_PUBLIC_URL=postgresql://postgres:password@public-host:5432/railway

# ═══════════════════════════════════════════════════════════════════
# ГОЛОСОВЫЕ СООБЩЕНИЯ (хотя бы один)
# ═══════════════════════════════════════════════════════════════════

# Groq API (БЕСПЛАТНО! whisper-large-v3)
GROQ_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API (платный, $0.006/мин)
# OPENAI_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════════
# ВЕБ-ДАШБОРД
# ═══════════════════════════════════════════════════════════════════

# URL дашборда (скопируй из Railway после деплоя)
DASHBOARD_URL=https://finora-bot-production.up.railway.app

# Flask секретный ключ для сессий (сгенерируй случайно)
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890

# ═══════════════════════════════════════════════════════════════════
# ОПЦИОНАЛЬНЫЕ
# ═══════════════════════════════════════════════════════════════════

# AI модель для советов (по умолчанию: claude-sonnet-4-5)
OR_MODEL=anthropic/claude-sonnet-4-5

# Порт для дашборда (Railway устанавливает автоматически)
# PORT=5000
